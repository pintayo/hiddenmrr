# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_super_secret_string

# GitHub OAuth App (Requires 'repo' scope access)
GITHUB_ID=your_github_oauth_client_id
GITHUB_SECRET=your_github_oauth_client_secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Lemon Squeezy
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# Server-side OpenAI key for free scans (removes BYOK friction for first-time users)
OPENAI_API_KEY=sk-your-server-openai-key

# Lemon Squeezy product URLs
NEXT_PUBLIC_LEMON_SQUEEZY_SINGLE_SCAN_URL=https://store.lemonsqueezy.com/checkout/buy/your-single-scan-id

# Frontend Variables
NEXT_PUBLIC_LEMON_SQUEEZY_CHECKOUT_URL=https://store.lemonsqueezy.com/checkout/buy/your-product-id
