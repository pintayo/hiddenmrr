# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_super_secret_string

# GitHub OAuth App (Requires 'repo' scope access)
GITHUB_ID=your_github_oauth_client_id
GITHUB_SECRET=your_github_oauth_client_secret

# Supabase (Ensure 'profiles' table uses text 'id' if unlinked from Supabase Auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Lemon Squeezy
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# LLM APIS (User provides BYOK on frontend, but backend may need it if testing)
# OPENAI_API_KEY=

# Frontend Variables
NEXT_PUBLIC_LEMON_SQUEEZY_CHECKOUT_URL=https://store.lemonsqueezy.com/checkout/buy/your-product-id
